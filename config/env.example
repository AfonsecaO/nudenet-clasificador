# Entorno: dev | prod (en prod no se exponen mensajes de excepción y se registran en tmp/logs/app.log)
APP_ENV=dev

# MySQL global (opcional; si no existe config/mysql_app.json se usan estas variables)
# MYSQL_APP_HOST=127.0.0.1
# MYSQL_APP_PORT=3306
# MYSQL_APP_USER=
# MYSQL_APP_PASS=
# MYSQL_APP_DATABASE=clasificador
